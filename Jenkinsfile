pipeline {
    agent any

    stages {
        stage('Checkout') {
            steps {
                echo 'Repository cloned successfully'
            }
        }

        stage('Build') {
            steps {
                echo 'Building HTML application'
            }
        }

        stage('Test') {
            steps {
                echo 'Testing HTML application'
            }
        }

        stage('Deploy') {
            steps {
                echo 'Deployment completed'
            }
        }
    }
}